# Sethu MVP - Environment Variables Example
# Copy to .env in backend/ folder and fill in your values

# Backend
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/sethu
JWT_SECRET=your-secret-key-here
CLIENT_URL=http://localhost:3000
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Deployment (Render)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/sethu
# JWT_SECRET=production-secret-key
# CLIENT_URL=https://your-mobile-app-url.com

# Deployment (Vercel - for web export)
# NEXT_PUBLIC_API_URL=https://your-backend-url.render.com
